# Server
APP_PORT=8080
APP_BASE_URL=https://vows.id

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vows
DB_USER=root
DB_PASSWORD=password

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_API_VERSION=v23.0
# Must match the "Verify Token" configured in the Meta App Dashboard webhook
# subscription (used for the GET hub.challenge handshake).
META_VERIFY_TOKEN=

# Optional approved template for the initial invitation message (must have an
# IMAGE header and a "guest_name" named body parameter). Leave blank to send
# freeform text/image instead.
META_TEMPLATE_NAME_INVITATION=
META_TEMPLATE_LANGUAGE=
