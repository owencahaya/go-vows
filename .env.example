# Server
APP_PORT=8080
APP_BASE_URL=https://vows.id

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vows
DB_USER=root
DB_PASSWORD=password

# Twilio WhatsApp API
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender must be a WhatsApp-enabled Twilio number (sandbox example below).
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Optional approved Content Template SIDs. Leave blank to send freeform text.
TWILIO_CONTENT_SID_INVITATION=
TWILIO_CONTENT_SID_REMINDER=
TWILIO_CONTENT_SID_QR=

# Optional public URL Twilio posts delivery/status callbacks to.
# Typically APP_BASE_URL + /api/webhook/whatsapp
TWILIO_STATUS_CALLBACK_URL=
